# Telegram Bot
BOT_TOKEN=
CHAT_ID=                         # Personal chat or group (negative number)
ALLOWED_USERS=                   # Comma-separated Telegram user IDs (e.g. 123456,789012)

# Schedule
TIMEZONE=Europe/Lisbon
SEARCH_INTERVAL_MIN=20           # Auto-search interval in minutes (8:00-23:00)

# Chrome (bare metal only, auto-detected if omitted)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Claude Code OAuth (Docker only)
# Get token: security find-generic-password -s "claude-cli" -w
# Get account info: cat ~/.claude.json | grep -A5 oauthAccount
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_ACCOUNT_UUID=
CLAUDE_EMAIL=
CLAUDE_ORG_UUID=
